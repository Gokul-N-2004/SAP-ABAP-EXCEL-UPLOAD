projection;
strict ( 2 );

define behavior for ZC_CZ301_USER alias User
{
  use create;
  use update;
  use delete;

  use action uploadExcelData;
  use action DownloadExcel;

  use association _UserDev { create; }
}

define behavior for ZC_CZ301_USER_DEV alias UserDev
{
  use update;
  use delete;

  use association _User;
}